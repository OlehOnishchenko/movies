<h1>👕 Магазин одягу</h1>
<hr>
<a href="/clothing/create" style="padding: 10px; background: #007bff; color: white; text-decoration: none; border-radius: 5px;">➕ Додати товар</a>
<br><br>

<table border="1" cellpadding="10" style="width: 100%; border-collapse: collapse;">
    <thead style="background: #eee;">
        <tr>
            <th>Тип</th>
            <th>Бренд</th>
            <th>Розмір</th>
            <th>Ціна</th>
            <th>На складі</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        {{#each items}}
        <tr>
            <td>{{this.type}}</td>
            <td>{{this.brand}}</td>
            <td>{{this.size}}</td>
            <td>${{this.price}}</td>
            <td>{{this.stock_quantity}} шт.</td>
            <td>
                <form action="/clothing/delete/{{this.id}}" method="POST" onsubmit="return confirm('Видалити цей товар?')">
                    <button type="submit" style="color: red; cursor: pointer;">Видалити</button>
                </form>
            </td>
        </tr>
        {{/each}}
    </tbody>
</table>
<br>
<a href="/">🏠 На головну</a>
