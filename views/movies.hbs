<table>
    <thead>
    <tr>
        <th scope="col">ID</th>
        <th scope="col">Title</th>
        <th scope="col">Director</th>
        <th scope="col">Release Year</th>
        <th scope="col">Rating</th>
        <th scope="col">Created At</th>
    </tr>
    </thead>
    <tbody>
    {{#each movies}}
        <tr>
            <th scope="row">{{this.id}}</th>
            <td>{{this.title}}</td>
            <td>{{this.director}}</td>
            <td>{{this.release_year}}</td>
            <td>{{this.rating}}</td>
            <td>{{this.created_at}}</td>
        </tr>
    {{/each}}
    </tbody>
</table>
